0:{"rsc":["$","$1","c",{"children":[[["$","h1",null,{"children":"Refund & Return Policy"}],["$","p",null,{"className":"text-sm text-gray-500","children":"Last Updated: March 2025"}],["$","p",null,{"children":"ReVia Research Supply LLC (\"ReVia\") maintains strict quality control standards for all products. Due to the nature of our research-use-only peptide products and the inability to verify the condition or handling of returned goods, we enforce the following refund and return policy."}],["$","h2",null,{"children":"1. All Sales Are Final"}],["$","p",null,{"children":[["$","strong",null,{"children":"All sales are final. We do not offer refunds, returns, or exchanges under normal circumstances."}]," ","By placing an order with ReVia, you acknowledge and agree that your purchase is non-refundable and non-returnable. We strongly encourage you to review your order carefully before completing your purchase, including product selection, quantities, and shipping address."]}],["$","h2",null,{"children":"2. Limited Exceptions"}],["$","p",null,{"children":"We may, at our sole discretion, provide a product replacement (not a cash refund) in the following limited circumstances:"}],["$","h3",null,{"children":"2.1 Damaged in Transit"}],["$","p",null,{"children":["If your order arrives with visible damage to the product or packaging that affects the integrity of the product, you must report the damage within ",["$","strong",null,{"children":"forty-eight (48) hours"}]," of delivery. To file a damage claim, email us at"," ",["$","a",null,{"href":"mailto:support@revia.bio","className":"text-blue-600 hover:underline","children":"support@revia.bio"}]," ","with:"]}],["$","ul",null,{"children":[["$","li",null,{"children":"Your order number"}],["$","li",null,{"children":"Clear photographs of the damaged packaging and product(s)"}],["$","li",null,{"children":"A brief description of the damage"}]]}],["$","h3",null,{"children":"2.2 Wrong Item Shipped"}],["$","p",null,{"children":["If you receive a product that differs from what you ordered, please contact us within ",["$","strong",null,{"children":"forty-eight (48) hours"}]," of delivery. Provide your order number, a photo of the item received, and a description of the discrepancy. We will arrange for the correct product to be shipped to you at no additional cost."]}],["$","h3",null,{"children":"2.3 Product Quality Issues"}],["$","p",null,{"children":["If you believe a product has a quality or integrity issue (e.g., contamination, incorrect concentration, or seal compromise), you must contact us within ",["$","strong",null,{"children":"seven (7) days"}]," of delivery. Include your order number, a description of the issue, and any supporting documentation or photographs. Our quality assurance team will review your claim and determine an appropriate resolution."]}],["$","h2",null,{"children":"3. Resolution Process"}],["$","p",null,{"children":["All approved claims under the exceptions described above will be resolved through ",["$","strong",null,{"children":"product replacement only"}],". ReVia does not issue cash refunds, store credit, or monetary compensation under any circumstances. Replacement products will be shipped using the same shipping method as the original order at no additional cost to the customer."]}],["$","h2",null,{"children":"4. Non-Eligible Situations"}],["$","p",null,{"children":["The following situations do ",["$","strong",null,{"children":"not"}]," qualify for replacement or refund:"]}],["$","ul",null,{"children":[["$","li",null,{"children":"Change of mind after purchase"}],["$","li",null,{"children":"Incorrect product or quantity selected by the customer"}],["$","li",null,{"children":"Products that have been opened, used, or tampered with"}],["$","li",null,{"children":"Products not stored according to recommended conditions"}],"$L2","$L3","$L4","$L5","$L6"]}],"$L7","$L8","$L9","$La","$Lb"],null,"$Lc"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"U_-VL4FeDpD8kth