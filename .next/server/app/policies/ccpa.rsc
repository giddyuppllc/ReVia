a:["$","$1","c",{"children":[[["$","h1",null,{"children":"California Consumer Privacy Act (CCPA) Notice"}],["$","p",null,{"className":"text-sm text-gray-500","children":"Last Updated: March 2025"}],["$","p",null,{"children":["This CCPA Notice supplements the information contained in the"," ",["$","a",null,{"href":"/policies/privacy","className":"text-blue-600 hover:underline","children":"Privacy Policy"}]," ","of ReVia Research Supply LLC (\"ReVia,\" \"we,\" \"us,\" or \"our\") and applies solely to residents of the State of California (\"consumers\" or \"you\"). This notice is provided in accordance with the California Consumer Privacy Act of 2018 (CCPA), as amended by the California Privacy Rights Act of 2020 (CPRA)."]}],["$","h2",null,{"children":"1. Your Rights Under the CCPA"}],["$","p",null,{"children":"As a California resident, you have the following rights regarding your personal information:"}],["$","h3",null,{"children":"1.1 Right to Know"}],["$","p",null,{"children":"You have the right to request that we disclose the categories and specific pieces of personal information we have collected about you, the categories of sources from which we collected your personal information, the business or commercial purpose for collecting your personal information, and the categories of third parties with whom we share your personal information."}],["$","h3",null,{"children":"1.2 Right to Delete"}],["$","p",null,{"children":"You have the right to request that we delete personal information we have collected from you, subject to certain exceptions. We may deny your deletion request if retaining the information is necessary for us or our service providers to complete a transaction, detect security incidents, comply with legal obligations, or exercise other rights permitted by law."}],["$","h3",null,{"children":"1.3 Right to Opt-Out of Sale"}],["$","p",null,{"children":"You have the right to opt out of the \"sale\" of your personal information. ReVia does not sell personal information in the traditional sense. However, certain activities such as targeted advertising may constitute a \"sale\" under the broad CCPA definition. You may exercise your right to opt out by contacting us or using the \"Do Not Sell My Personal Information\" mechanism described below."}],["$","h3",null,{"children":"1.4 Right to Non-Discrimination"}],["$","p",null,{"children":"We will not discriminate against you for exercising any of your CCPA rights. We will not deny you goods or services, charge you different prices or rates, provide you a different level or quality of goods or services, or suggest that you may receive a different price or rate or different level or quality of goods or services as a result of exercising your rights."}],["$","h3",null,{"children":"1.5 Right to Correct"}],["$","p",null,{"children":"You have the right to request that we correct inaccurate personal information that we maintain about you."}],["$","h2",null,{"children":"2. Categories of Personal Information Collected"}],["$","p",null,{"children":"In the preceding twelve (12) months, we may have collected the following categories of personal information from California consumers:"}],["$","div",null,{"className":"not-prose overflow-x-auto","children":["$","table",null,{"className":"w-full text-sm border border-gray-200 rounded-lg","children":[["$","thead",null,{"className":"bg-gray-50","children":["$","tr",null,{"children":[["$","th",null,{"className":"px-4 py-3 text-left font-semibold text-gray-700 border-b","children":"Category"}],["$","th",null,{"className":"px-4 py-3 text-left font-semibold text-gray-700 border-b","children":"Examples"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"className":"border-b border-gray-100","children":["$Lf","$L10"]}],"$L11","$L12","$L13","$L14"]}]]}]}],"$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23"],null,"$L24"]}]
