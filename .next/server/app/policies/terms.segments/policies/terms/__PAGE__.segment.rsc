,"li",null,{"children":"Promptly update your account information to keep it accurate and complete."}],["$","li",null,{"children":"Notify us immediately of any unauthorized use of your account or any other breach of security."}],["$","li",null,{"children":"Accept responsibility for all activities that occur under your account."}]]}],["$","p",null,{"children":"ReVia shall not be liable for any loss or damage arising from your failure to comply with these obligations."}],["$","h2",null,{"children":"4. Products and Research-Use-Only Designation"}],["$","p",null,{"children":["All products sold through the Site are designated"," ",["$","strong",null,{"children":"\"For Research Use Only — Not for Human Consumption.\""}]," ","Our products are intended solely for in-vitro research and laboratory use by qualified researchers and institutions. Products sold by ReVia are not drugs, are not intended to diagnose, treat, cure, or prevent any disease, and have not been approved by the U.S. Food and Drug Administration (FDA) or any other regulatory body for human or animal use."]}],["$","p",null,{"children":"By purchasing any product from ReVia, you acknowledge and agree that you will use the product solely for legitimate research purposes in compliance with all applicable laws and regulations."}],["$","h2",null,{"children":"5. Ordering and Pricing"}],["$","p",null,{"children":"All prices listed on the Site are in United States Dollars (USD) and are subject to change without notice. We reserve the right to modify or discontinue any product at any time. While we make every effort to ensure the accuracy of product descriptions and pricing, errors may occur. In the event of a pricing error, we reserve the right to cancel any orders placed at the incorrect price and will notify you promptly."}],"$L2","$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15"],null,"$L16"]}],"isPartial":false,"staleTime":300,"varyParams":null,"