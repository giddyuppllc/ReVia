0:{"rsc":["$","$1","c",{"children":[[["$","h1",null,{"children":"Cookie Policy"}],["$","p",null,{"className":"text-sm text-gray-500","children":"Last Updated: March 2025"}],["$","p",null,{"children":"ReVia Research Supply LLC (\"ReVia,\" \"we,\" \"us,\" or \"our\") uses cookies and similar tracking technologies on our website at revia.bio (the \"Site\"). This Cookie Policy explains what cookies are, how we use them, and how you can manage your preferences."}],["$","h2",null,{"children":"1. What Are Cookies?"}],["$","p",null,{"children":"Cookies are small text files that are placed on your device (computer, tablet, or mobile phone) when you visit a website. Cookies are widely used to make websites function properly, improve performance, and provide information to site owners. Cookies may be \"session\" cookies (deleted when you close your browser) or \"persistent\" cookies (remaining on your device for a set period or until you delete them)."}],["$","h2",null,{"children":"2. Types of Cookies We Use"}],["$","h3",null,{"children":"2.1 Essential Cookies"}],["$","p",null,{"children":"These cookies are strictly necessary for the operation of the Site. They enable core functionality such as security, account authentication, session management, and shopping cart operations. The Site cannot function properly without these cookies, and they cannot be disabled."}],["$","ul",null,{"children":[["$","li",null,{"children":"Session identification"}],["$","li",null,{"children":"Authentication tokens"}],["$","li",null,{"children":"Shopping cart state"}],["$","li",null,{"children":"Security and fraud prevention (CSRF tokens)"}]]}],["$","h3",null,{"children":"2.2 Analytics Cookies"}],["$","p",null,{"children":"These cookies help us understand how visitors interact with the Site by collecting and reporting information anonymously. They allow us to measure traffic, identify popular pages, and improve the user experience."}],["$","ul",null,{"children":[["$","li",null,{"children":"Google Analytics (traffic analysis, user behavior, page performance)"}],["$","li",null,{"children":"Aggregate usage statistics"}]]}],["$","h3",null,{"children":"2.3 Functional Cookies"}],["$","p",null,{"children":"These cookies enable enhanced functionality and personalization, such as remembering your preferences, language settings, and display options. They may be set by us or by third-party providers whose services we have integrated into our pages."}],["$","ul",null,{"children":[["$","li",null,{"children":"User preference storage (e.g., theme, language)"}],["$","li",null,{"children":"Recently viewed products"}],["$","li",null,{"children":"Form auto-fill data"}]]}],["$","h3",null,{"children":"2.4 Marketing Cookies"}],["$","p",null,{"children":"These cookies may be set through our Site by advertising partners. They may be used to build a profile of your interests and show you relevant advertisements on other sites. They do not directly store personal information but are based on uniquely identifying your browser and device."}],["$","h2",null,{"children":"3. Third-Party Cookies"}],["$","p",null,{"children":"In addition to our own cookies, we may use cookies set by third parties to provide certain features and services:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Google Analytics:"}],"Used to analyze Site traffic and usage patterns. Google's privacy policy is available at"," ",["$","a",null,{"href":"https://policies.google.com/privacy","className":"text-blue-600 hover:underline","target":"_blank","rel":"noopener noreferrer","children":"policies.google.com/privacy"}],"."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payment Processors:"}]," Our payment providers (e.g., Stripe) may set cookies to facilitate secure payment processing and fraud detection."]}]]}],"$L2","$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13"],null,"$L14"]}],"isPartial":false,"staleTim