5:["$","p",null,{"children":"We may also disclose your information when required by law, to respond to legal process, to protect our rights and safety, or in connection with a merger, acquisition, or sale of assets."}]
6:["$","h2",null,{"children":"4. Data Retention"}]
7:["$","p",null,{"children":"We retain your personal information for as long as necessary to fulfill the purposes for which it was collected, including to satisfy legal, accounting, or reporting requirements. Order records and transaction data are retained for a minimum of seven (7) years to comply with tax and regulatory obligations. You may request deletion of your account data at any time, subject to our legal retention requirements."}]
8:["$","h2",null,{"children":"5. Data Security"}]
9:["$","p",null,{"children":"We implement appropriate technical and organizational security measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction. These measures include:"}]
a:["$","ul",null,{"children":[["$","li",null,{"children":"SSL/TLS encryption for all data transmitted between your browser and our servers"}],["$","li",null,{"children":"PCI-DSS compliant payment processing"}],["$","li",null,{"children":"Access controls limiting employee access to personal data on a need-to-know basis"}],["$","li",null,{"children":"Regular security assessments and vulnerability testing"}],["$","li",null,{"children":"Encrypted data storage"}]]}]
b:["$","p",null,{"children":"While we strive to protect your information, no method of transmission over the Internet or electronic storage is completely secure, and we cannot guarantee absolute security."}]
c:["$","h2",null,{"children":"6. Your Rights"}]
d:["$","p",null,{"children":"Depending on your jurisdiction, you may have the following rights regarding your personal information:"}]
e:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Right to Access:"}]," You may request a copy of the personal information we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Correction:"}]," You may request that we correct inaccurate or incomplete personal information."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Deletion:"}]," You may request that we delete your personal information, subject to certain legal exceptions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Data Portability:"}]," You may request your data in a structured, commonly used, machine-readable format."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Object:"}]," You may object to certain processing of your personal information, including direct marketing."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Restrict Processing:"}]," You may request that we restrict the processing of your personal information under certain circumstances."]}]]}]
f:["$","p",null,{"children":["To exercise any of these rights, please contact us at"," ",["$","a",null,{"href":"mailto:support@revia.bio","className":"text-blue-600 hover:underline","children":"support@revia.bio"}],". We will respond to your request within thirty (30) days."]}]
10:["$","h2",null,{"children":"7. GDPR Compliance"}]
11:["$","p",null,{"children":"If you are located in the European Economic Area (EEA), the United Kingdom, or Switzerland, you have additional rights under the General Data Protection Regulation (GDPR). We process your personal data based on the following legal bases:"}]
12:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Contractual necessity:"}]," Processing necessary to fulfill our contract with you (e.g., order fulfillment)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legitimate interest:"}]," Processing necessary for our legitimate business interests (e.g., fraud prevention, analytics)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Consent:"}]," Where you have provided explicit consent (e.g., marketing communications)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal obligation:"}]," Processing necessary to comply with applicable laws."]}]]}]
13:["$","p",null,{"children":"You may withdraw consent at any time. You also have the right to lodge a complaint with your local data protection supervisory authority."}]
14:["$","h2",null,{"children":"8. Children's Privacy"}]
15:["$","p",null,{"children":["The Site is not intended for use by individuals under the age of eighteen (18). We do not knowingly collect personal information from anyone under 18. If we become aware that we have collected personal information from a minor, we will take steps to delete that information promptly. If you believe we have inadvertently collected information from a minor, please contact us immediately at"," ",["$","a",null,{"href":"mailto:support@revia.bio","className":"text-blue-600 hover:underline","children":"support@revia.bio"}],"."]}]
16:["$","h2",null,{"children":"9. International Data Transfers"}]
17:["$","p",null,{"children":"If you are accessing the Site from outside the United States, please be aware that your information may be transferred to, stored, and processed in the United States, where our servers are located. By using the Site, you consent to the transfer of your information to the United States, which may have data protection laws that differ from those in your country. We take appropriate safeguards to ensure your data is protected in accordance with this Privacy Policy and applicable law."}]
18:["$","h2",null,{"children":"10. Changes to This Privacy Policy"}]
19:["$","p",null,{"children":"We may update this Privacy Policy from time to time. The \"Last Updated\" date at the top of this page reflects the most recent revision. We encourage you to review this Privacy Policy periodically. Your continued use of the Site after any changes constitutes your acceptance of the revised policy."}]
1a:["$","h2",null,{"children":"11. Contact Us"}]
